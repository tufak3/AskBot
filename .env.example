# ── Telegram ────────────────────────────────────────────────
# Токен бота из @BotFather (команда /token или при создании /newbot).
# НИКОГДА не коммить реальный токен — только этот пример.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_token_here

# ── Groq (LLM) ──────────────────────────────────────────────
# Ключ с console.groq.com → API Keys (бесплатно, без карты).
GROQ_API_KEY=gsk_your_key_here

# ── Google Sheets (база знаний) ─────────────────────────────
# ID таблицы из её URL: docs.google.com/spreadsheets/d/<ЭТОТ_ID>/edit
GOOGLE_SHEET_ID=your_sheet_id_here
# (необязательно) путь к JSON-ключу сервисного аккаунта; по умолчанию service-account.json
# GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json
# (для хостинга) вместо файла — всё содержимое JSON-ключа одной строкой:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Оператор ────────────────────────────────────────────────
# Chat ID, куда приходят уведомления о «горячих» клиентах.
# Узнать свой ID можно у бота @userinfobot.
OPERATOR_CHAT_ID=123456789
